# GEMINI_API_KEY: Required for Gemini AI API calls on the C# ASP.NET Core backend.
# Set this in the Secrets panel if using AI Studio, or in your local environment.
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# VITE_CLIENT_ID / VITE_CLIENT_SECRET:
# Used by the React SPA (via Axios) to acquire a JWT Bearer token from the C# Auth API.
# These must match the values configured in Web.Api/appsettings.json > AuthSettings.
VITE_CLIENT_ID="YOUR_CLIENT_ID"
VITE_CLIENT_SECRET="YOUR_CLIENT_SECRET"

# VITE_API_TARGET:
# Vite dev server proxy target for /api/* requests.
# Change to https://localhost:5001 for HTTPS.
VITE_API_TARGET="http://localhost:5000"
