{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "AuthSettings": {
    "ClientId": "YOUR_CLIENT_ID",
    "ClientSecret": "YOUR_CLIENT_SECRET",
    "JwtKey": "YOUR_SECURE_JWT_SIGNING_KEY",
    "JwtIssuer": "SanskritQuest.Main.Web.Api",
    "JwtAudience": "SanskritQuestApp",
    "ExpiryMinutes": 120
  }
}
